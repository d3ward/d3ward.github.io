---
import Icon from "../common/Icon.astro";

// CSS grid class for each area is `gs-${area}` — must match grid-template-areas in styles.css
const AREA_CONFIG = {
  logo:      { icon: null,                      classes: "bg-white text-blue-500 border-4 border-blue-500 aspect-square" },
  gh:        { icon: "tabler:brand-github",     classes: "bg-white text-blue-500"                                        },
  stars:     { icon: "tabler:star",             classes: "bg-blue-50 text-blue-700 aspect-square"                        },
  followers: { icon: "tabler:users-group",      classes: "bg-blue-50 text-blue-700"                                      },
  commits:   { icon: "tabler:git-commit",       classes: "bg-blue-50 text-blue-700 aspect-square"                        },
  issues:    { icon: "tabler:circle-dot",       classes: "bg-blue-500 text-white aspect-square"                          },
  pr:        { icon: "tabler:git-pull-request", classes: "bg-blue-600 text-white"                                        },
  repos:     { icon: "tabler:book-2",           classes: "bg-blue-600 text-white"                                        },
} as const;

type AreaType = keyof typeof AREA_CONFIG;

interface Props {
  value?: string | number;
  label?: string;
  icon?: string;
  href?: string;
  area: AreaType;
  animation?: "left" | "right" | "top" | "bottom";
  showLabelOnMobile?: boolean;
  noJsValue?: string | number;
  tilt?: boolean;
  tiltMax?: number;
  tiltSpeed?: number;
  tiltPerspective?: number;
}

const {
  value = "",
  label = "",
  icon,
  href,
  area,
  animation = "bottom",
  showLabelOnMobile = true,
  noJsValue,
  tilt = true,
  tiltMax = 15,
  tiltSpeed = 400,
  tiltPerspective = 1000,
} = Astro.props;

const resolvedIcon = icon || AREA_CONFIG[area].icon;
const isLogo = area === "logo";
const isLink = href ? true : false;

const Tag = href ? "a" : "div";
const linkAttrs = href ? { href, target: "_blank", "aria-label": label } : {};
const tiltAttrs = tilt
  ? {
      "data-tilt": "",
      "data-tilt-max": tiltMax,
      "data-tilt-speed": tiltSpeed,
      "data-tilt-perspective": tiltPerspective,
    }
  : {};
---

<Tag
  class:list={[
    `gs-${area}`,
    AREA_CONFIG[area].classes,
    "relative flex flex-col items-center justify-center overflow-hidden rounded-lg p-4 text-center transition-all duration-700",
    animation &&
      {
        left: "_aos-left",
        right: "_aos-right",
        top: "_aos-top",
        bottom: "_aos-bottom",
      }[animation],
  ]}
  {...linkAttrs}
  {...tiltAttrs}
>
  <span class="gs-ripple"></span>

  {
    isLogo ? (
      <div class="z-10">
        <slot />
      </div>
    ) : isLink ? (
      <div class="z-10">
        <Icon
          name="tabler:external-link"
          class="absolute top-2 right-2 z-10 h-6 w-6"
        />
        {resolvedIcon && <Icon name={resolvedIcon} size="xl" />}
        <slot />
      </div>
    ) : (
      <div class="z-10 flex flex-col items-center">
        {noJsValue && (
          <span class="count no-js mb-2 text-3xl leading-none font-medium">
            {noJsValue}
          </span>
        )}
        {value && (
          <span
            class="count mb-2 text-3xl leading-none font-medium"
            data-target={value}
          >
            {value}
          </span>
        )}
        {label && (
          <label class="flex items-center justify-center gap-1 text-base font-medium">
            {resolvedIcon && <Icon name={resolvedIcon} />}
            <span class:list={[!showLabelOnMobile && "hidden md:block"]}>
              {label}
            </span>
          </label>
        )}
      </div>
    )
  }
</Tag>
