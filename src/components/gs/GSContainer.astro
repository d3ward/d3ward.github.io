---
import "./styles.css";

interface Props {
  class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["grid-stats", className]}>
  <slot />
</div>

<script>
  import { withLifecycle } from "@scripts/lifecycle";

  withLifecycle(() => {
    const timers: ReturnType<typeof setInterval>[] = [];

    // Animate counters
    document.querySelectorAll(".count[data-target]").forEach((counter) => {
      const target = parseInt(counter.getAttribute("data-target") || "0");
      if (!target) return;
      let current = 0;
      const timer = setInterval(() => {
        current++;
        counter.textContent = current.toString();
        if (current === target) clearInterval(timer);
      }, 2000 / target);
      timers.push(timer);
    });

    // Logo animation — 300ms delay so the stroke draw is visible
    const logo = document.getElementById("d3Logo");
    const logoTimeout = logo
      ? setTimeout(() => logo.classList.add("startA"), 300)
      : null;

    // Ripple effect — listeners are on replaced DOM nodes, no manual cleanup needed
    document.querySelectorAll(".grid-stats > *").forEach((element) => {
      const ripple = element.querySelector(".gs-ripple") as HTMLElement | null;
      if (!ripple) return;

      function setRipplePosition(e: MouseEvent) {
        const rect = (element as HTMLElement).getBoundingClientRect();
        ripple!.style.left = e.clientX - rect.left + "px";
        ripple!.style.top = e.clientY - rect.top + "px";
      }

      element.addEventListener("mouseover", ((e: MouseEvent) => {
        if (element.classList.contains("gs-logo")) element.classList.add("transition-2");
        setRipplePosition(e);
      }) as EventListener);

      element.addEventListener("mouseout", ((e: MouseEvent) => {
        setRipplePosition(e);
      }) as EventListener);
    });

    return () => {
      timers.forEach(clearInterval);
      if (logoTimeout !== null) clearTimeout(logoTimeout);
    };
  });
</script>
