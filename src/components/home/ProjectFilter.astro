---
import Filter from "../common/Filter.astro";
import { PROJECT_FILTERS } from "@data/filters";

interface Props {
  activeFilter?: string;
}

const { activeFilter = "all" } = Astro.props;
---

<Filter
  options={PROJECT_FILTERS}
  activeFilter={activeFilter}
  class="mb-12 flex flex-wrap justify-center gap-3"
  size="sm"
/>
