---
import Button from "./common/Button.astro";
---

<Button
  id="go-to-top"
  color="primary"
  circle={true}
  icon="tabler:arrow-up"
  iconOnly={true}
  class="fixed right-8 bottom-8 z-40 opacity-0 shadow-lg transition-opacity duration-300"
  aria-label="Go to top"
/>

<script>
  import { withLifecycle } from "@scripts/lifecycle";

  withLifecycle(() => {
    const btn = document.getElementById("go-to-top") as HTMLElement | null;
    if (!btn) return;

    function handleScroll() {
      const past = window.scrollY > 300;
      btn!.style.opacity = past ? "1" : "0";
      btn!.style.pointerEvents = past ? "auto" : "none";
    }

    function handleClick() {
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    btn.addEventListener("click", handleClick);

    return () => {
      window.removeEventListener("scroll", handleScroll);
      btn!.removeEventListener("click", handleClick);
    };
  });
</script>
