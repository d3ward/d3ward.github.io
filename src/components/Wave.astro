---
interface Props {
  position?: "top" | "bottom";
  className?: string;
}

const { position = "bottom", className = "" } = Astro.props;
---

<svg
  viewBox={position === "top" ? "0 0 120 30" : "0 0 120 12"}
  class={`wave ${className}`}
  style={position === "top"
    ? ""
    : "margin-bottom:-7px;margin-top:2rem;height:5em;"}
  preserveAspectRatio="none"
>
  {
    position === "top" ? (
      <path d="M0 9v6c30 0 30 4 60 4 31 0 30-4 60-4s30 4 60 4 30-4 60-4V0H0z" />
    ) : (
      <path d="M 0 0 C 30 0 30 5 60 5 C 90 5 90 0 120 0 C 150 0 150 5 180 5 C 210 5 210 0 240 0 v 12 h -240 z" />
    )
  }
</svg>

<style>
  svg.wave {
    display: block;
    width: 100%;
    height: 15em;
    max-height: 100vh;
    margin: 0;
  }

  svg.wave > path {
    fill: currentColor;
    animation: wave 10s linear infinite;
  }

  @keyframes wave {
    0% {
      transform: translateX(0);
    }

    100% {
      transform: translateX(-100%);
    }
  }
</style>
