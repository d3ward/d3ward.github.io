---
/**
 * Modal Component
 *
 * Accessible modal using a11y-dialog with daisyUI styling.
 * Can be opened using: data-a11y-dialog-show="id" on any trigger element
 * Can be closed using: Esc key, clicking backdrop, or data-a11y-dialog-hide
 *
 * @prop {string} id - Required unique ID for the modal
 * @prop {string} class - Additional classes for the modal wrapper
 * @prop {string} boxClass - Classes for modal-box
 * @prop {string} actionClass - Classes for modal-action
 * @prop {boolean} closeOnBackdrop - Allow closing by clicking outside (default: true)
 * @prop {boolean} closeButton - Show close button in top-right corner (default: false)
 *
 * Slots:
 * - default: Modal content
 * - actions: Modal action buttons (uses modal-action class)
 * - title: Modal title/header
 */

interface Props {
  id: string;
  class?: string;
  boxClass?: string;
  actionClass?: string;
  closeOnBackdrop?: boolean;
  closeButton?: boolean;
}

const {
  id,
  class: className,
  boxClass,
  actionClass,
  closeOnBackdrop = true,
  closeButton = false,
  ...rest
} = Astro.props;

const titleId = `${id}-title`;
---

<div
  id={id}
  aria-labelledby={titleId}
  aria-hidden="true"
  data-a11y-dialog
  class:list={["modal-container", className]}
  {...rest}
>
  <div
    class="modal-overlay"
    {...closeOnBackdrop ? { "data-a11y-dialog-hide": true } : {}}
  >
  </div>

  <div role="document" class:list={["modal-box", boxClass]}>
    {
      closeButton && (
        <button
          type="button"
          data-a11y-dialog-hide
          class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2"
          aria-label="Close dialog"
        >
          ✕
        </button>
      )
    }

    <div id={titleId}>
      <slot name="title" />
    </div>

    <slot />

    {
      Astro.slots.has("actions") && (
        <div class:list={["modal-action", actionClass]}>
          <slot name="actions" />
        </div>
      )
    }
  </div>
</div>

<script>
  import A11yDialog from "a11y-dialog";

  function initDialogs() {
    document
      .querySelectorAll<HTMLElement>("[data-a11y-dialog]")
      .forEach((el) => {
        if (!el.dataset.a11yDialogInit) {
          new A11yDialog(el);
          el.dataset.a11yDialogInit = "true";
        }
      });
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initDialogs);
  } else {
    initDialogs();
  }

  document.addEventListener("astro:page-load", initDialogs);
</script>

<style is:global>
  .modal-container {
    display: flex;
    position: fixed;
    inset: 0;
    z-index: 999;
    align-items: center;
    justify-content: center;
  }

  .modal-container[aria-hidden="true"] {
    display: none;
  }

  .modal-container .modal-overlay {
    position: fixed;
    inset: 0;
    background-color: oklch(0% 0 0 / 0.4);
    backdrop-filter: blur(2px);
  }

  .modal-container .modal-box {
    position: relative;
    z-index: 1;
    scale: 1;
    opacity: 1;
  }
</style>
