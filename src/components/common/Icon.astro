---
import { Icon as AstroIcon } from "astro-icy/components";

interface Props {
  name: string;
  class?: string;
  size?: "xs" | "sm" | "md" | "lg" | "xl" | "2xl" | "3xl" | "4xl" | "5xl";
}

const { name, class: className, size = "md", ...rest } = Astro.props;

const sizeMap: Record<string, string> = {
  xs: "w-3 h-3",
  sm: "w-4 h-4",
  md: "w-6 h-6",
  lg: "w-8 h-8",
  xl: "w-10 h-10",
  "2xl": "w-12 h-12",
  "3xl": "w-16 h-16",
  "4xl": "w-20 h-20",
  "5xl": "w-24 h-24",
};

const finalClass = className || sizeMap[size] || "w-6 h-6";
---

<AstroIcon name={name} class={finalClass} {...rest} />
